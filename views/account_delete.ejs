<%- include("layout", { title: "Excluir conta", body: `
  <div class="card" style="max-width:760px;margin:0 auto;">
    <div class="h">Excluir minha conta</div>

    <div class="card" style="margin-top:12px;border-color:#6b2033;background:#2a0a12;">
      <b>Atenção:</b> isso é irreversível. Sua conta e todo o conteúdo ligado a ela serão apagados.
    </div>

    ${error ? `<div class="card" style="margin-top:12px;border-color:#6b2033;background:#2a0a12;">${error}</div>` : ""}

    <form method="post" action="/account/delete" style="margin-top:14px;" data-no-loader="1">
      <label class="lbl">Digite sua senha</label>
      <input class="inp" type="password" name="password" required />

      <label class="lbl" style="margin-top:10px;">Para confirmar, digite <b>EXCLUIR</b></label>
      <input class="inp" type="text" name="confirm" required />

      <div style="display:flex;gap:10px;margin-top:14px;flex-wrap:wrap;">
        <button class="btn danger" type="submit">Excluir definitivamente</button>
        <a class="btn ghost" href="/profile/edit">Cancelar</a>
      </div>
    </form>
  </div>
` }) %>