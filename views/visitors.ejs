<%- include("layout", { title: "Visitantes", body: `
  <div class="card">
    <div class="h">Meus visitantes</div>

    ${blocked ? `
      <div class="notice">
        Você está em <b>modo invisível</b>. Para ver seus visitantes, desative em
        <a href="/profile/edit">Editar perfil</a>.
      </div>
    ` : `
      <div class="row" style="justify-content:space-between; align-items:center; gap:10px;">
        <div class="small">Total: <b>${total}</b></div>
        <div class="filters">
          <a class="${range==='all'?'active':''}" href="/me/visitors?range=all">Tudo</a>
          <a class="${range==='24h'?'active':''}" href="/me/visitors?range=24h">24h</a>
          <a class="${range==='7d'?'active':''}" href="/me/visitors?range=7d">7 dias</a>
          <a class="${range==='30d'?'active':''}" href="/me/visitors?range=30d">30 dias</a>
        </div>
      </div>
      <hr/>

      ${visits.length ? `
        <table class="table">
          <thead><tr><th>Usuário</th><th>Nome</th><th>Quando</th></tr></thead>
          <tbody>
            ${visits.map(v => `
              <tr>
                <td style="display:flex; align-items:center; gap:10px;">
                  <img class="avatar sm" src="${photoSrc(v.profile_photo)}" alt="" />
                  <a href="/u/${v.username}">${v.username}</a>
                </td>
                <td>${v.full_name || ""}</td>
                <td class="small">${new Date(v.created_at).toLocaleString()}</td>
              </tr>
            `).join("")}
          </tbody>
        </table>
      ` : `<div class="small">Sem visitas nesse período.</div>`}

      ${pages > 1 ? `
        <div class="pager">
          ${page > 1 ? `<a class="btn secondary" href="/me/visitors?range=${range}&page=${page-1}">← Anterior</a>` : `<span></span>`}
          <div class="small">Página <b>${page}</b> de <b>${pages}</b></div>
          ${page < pages ? `<a class="btn secondary" href="/me/visitors?range=${range}&page=${page+1}">Próxima →</a>` : `<span></span>`}
        </div>
      ` : ``}
    `}
  </div>
` }) %>
