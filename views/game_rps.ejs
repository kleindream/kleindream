<%- include("layout", { title: "Pedra, Papel e Tesoura", body: `
<div class="game-page-grid">
  <div class="card game-wrap">
    <div class="h" style="font-size:1.8rem;font-weight:900;color:var(--accent);">✊ Pedra, Papel e Tesoura</div>
    <div class="game-stage">
      <div class="rps-grid">
        <button class="rps-btn" data-rps="pedra">✊ Pedra</button>
        <button class="rps-btn" data-rps="papel">✋ Papel</button>
        <button class="rps-btn" data-rps="tesoura">✌️ Tesoura</button>
      </div>
      <div class="game-toolbar"><span class="pill">Você: <b id="rpsYou">0</b></span><span class="pill">Klein Dream: <b id="rpsCpu">0</b></span><a class="button secondary" href="/games">Voltar</a></div>
      <div id="rpsStatus"></div>
      <div class="small">O ranking salva a maior quantidade de vitórias que você atingir nesta sessão do jogo.</div>
    </div>
  </div>
  <div class="card ranking-card">
    <div class="overview-title">🏆 Ranking do jogo</div>
    <div class="game-toolbar"><span class="pill">Seu melhor: <b id="gameMyBest">${myBest ? myBest.score : "—"}</b></span></div>
    <div id="gameRankingList" class="ranking-list">
      ${ranking.length ? ranking.map((row, idx) => `
        <div class="ranking-row">
          <span class="ranking-pos">${idx + 1}º</span>
          <span class="ranking-name">${row.username}</span>
          <span class="ranking-score">${row.score}</span>
        </div>
      `).join("") : `<div class="small">Ainda não há pontuações salvas para este jogo.</div>`}
    </div>
    <div id="gameSaveStatus" class="small" style="margin-top:10px;"></div>
  </div>
</div>
<script>window.__GAME_KEY__ = "rps"; window.__MY_BEST__ = ${myBest ? myBest.score : 'null'};</script>
<script src="/games/common.js"></script>
<script src="/games/rps.js"></script>
` }) %>
