<%- include("layout", { title: "Editar perfil", body: `
  <div class="card">
    <div class="h">Editar perfil</div>
        <div class="card" style="margin-top:10px;">
          <div class="h" style="margin-bottom:8px;">Foto de perfil</div>
          <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
            <div>
              ${me.profile_photo ? `<img src="/uploads/${me.profile_photo}" class="avatar kd-zoom" alt="Foto de perfil" style="width:96px;height:96px;border-radius:14px;object-fit:cover;" />` : `<div class="avatar" style="width:96px;height:96px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:var(--panel2);color:var(--muted);font-weight:800;">Sem foto</div>`}
            </div>
            <div style="flex:1;min-width:220px;">
              <label class="small">Enviar nova foto</label>
              <input type="file" name="profile_photo" accept="image/*" />
              <div class="small" style="margin-top:6px;opacity:.9;">Dica: clique numa foto para ampliar.</div>
            </div>
          </div>
        </div>
    ${error ? `<div class="card" style="border-color:#6b2033;background:#2a0a12;">${error}</div>` : ""}
    ${ok ? `<div class="card" style="border-color:#1e5f2b;background:#0b2411;">${ok}</div>` : ""}

    <form method="post" action="/profile/edit" enctype="multipart/form-data">
      <div class="h" style="margin-top:0">Básico</div>

      <label class="small">Nome completo</label>
      <input name="full_name" value="${me.full_name || ""}" />

      <br/><br/>
      <label class="small">Cidade</label>
      <input name="city" value="${me.city || ""}" />

      <br/><br/>
      <label class="small">Estado</label>
      <input name="state" value="${me.state || ""}" />

      <br/><br/>
      <label class="small">Sobre mim</label>
      <textarea name="bio">${me.bio || ""}</textarea>

      <br/><br/>
      <div class="h">Detalhes</div>

      <label class="small">Data de nascimento</label>
      <input type="date" name="birth_date" value="${me.birth_date || ""}" />

      <br/><br/>
      <label class="small">Estado civil</label>
      <select name="marital_status">
        ${["", "Solteiro(a)", "Namorando", "Casado(a)", "Separado(a)", "Divorciado(a)", "Viúvo(a)", "É complicado"].map(v => `<option value="${v}" ${String(me.marital_status||"")===v?"selected":""}>${v||"(não informar)"}</option>`).join("")}
      </select>

      <br/><br/>
      <label class="small">Time de futebol</label>
      <input name="favorite_team" value="${me.favorite_team || ""}" placeholder="Ex: Flamengo" />

      <br/><br/>
      <label class="small">Profissão</label>
      <input name="profession" value="${me.profession || ""}" placeholder="Ex: Técnico de informática" />

      <br/><br/>
      <div class="h">Gostos</div>

      <label class="small">Hobbies / Interesses</label>
      <input name="hobbies" value="${me.hobbies || ""}" placeholder="Ex: games, VHS, fóruns, terror" />

      <br/><br/>
      <label class="small">Música favorita</label>
      <input name="favorite_music" value="${me.favorite_music || ""}" />

      <br/><br/>
      <label class="small">Filme favorito</label>
      <input name="favorite_movie" value="${me.favorite_movie || ""}" />

      <br/><br/>
      <label class="small">Jogo favorito</label>
      <input name="favorite_game" value="${me.favorite_game || ""}" />

      <br/><br/>
      <div class="h">Social</div>

      <label class="small">Traços / Personalidade</label>
      <input name="personality" value="${me.personality || ""}" placeholder="Ex: otimista, realista, perfeccionista" />

      <br/><br/>
      <label class="small">O que procura aqui</label>
      <select name="looking_for">
        ${["", "Amizade", "Networking", "Relacionamento", "Comunidades"].map(v => `<option value="${v}" ${String(me.looking_for||"")===v?"selected":""}>${v||"(não informar)"}</option>`).join("")}
      </select>

      <br/><br/>
      <label class="small">Humor de hoje</label>
      <select name="mood">
        ${["", "😀 Feliz", "😐 Neutro", "😔 Triste", "😡 Irritado", "😎 De boa"].map(v => `<option value="${v}" ${String(me.mood||"")===v?"selected":""}>${v||"(não informar)"}</option>`).join("")}
      </select>

      <br/><br/>
      <label class="small">Frase do dia</label>
      <input name="daily_phrase" value="${me.daily_phrase || ""}" />

      <br/>
      <button class="btn" type="submit">Salvar</button>
    </form>
  </div>
` }) %>
