<%- include("layout", { title: "Amigos", body: `
  <div class="card">
    <div class="h">Meus amigos</div>
    ${friends.length ? `
      <div class="small" style="margin-bottom:12px;">Total: ${total} amigo${total === 1 ? '' : 's'}</div>
      <div class="thumb-grid compact-people-grid">
        ${friends.map(f => `
          <div class="thumb-card">
            <a href="/u/${f.username}" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;align-items:center;gap:6px;width:100%;">
              ${f.profile_photo
                ? `<img class="thumb-avatar kd-zoom" src="${photoSrc(f.profile_photo)}" alt="${escapeHtml(f.username)}" />`
                : `<div class="thumb-avatar ph">?</div>`}
              <div class="thumb-name">${escapeHtml(f.full_name || f.username)}</div>
              <div class="small">@${escapeHtml(f.username)}</div>
            </a>
            <form method="post" action="/friends/remove/${f.id}">
              <button class="btn danger mini" type="submit">Remover</button>
            </form>
          </div>
        `).join("")}
      </div>
      <div class="kd-pagination" style="display:flex;justify-content:space-between;align-items:center;gap:10px;margin-top:12px;flex-wrap:wrap;">
        <div style="opacity:.9;">Página ${page} de ${pages}</div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
          ${page > 1 ? `<a class="btn ghost" href="/friends?page=${page-1}">← Anterior</a>` : `<span class="btn ghost" style="opacity:.4;pointer-events:none;">← Anterior</span>`}
          ${page < pages ? `<a class="btn ghost" href="/friends?page=${page+1}">Próxima →</a>` : `<span class="btn ghost" style="opacity:.4;pointer-events:none;">Próxima →</span>`}
        </div>
      </div>
    ` : `<div class="small">Você ainda não tem amigos aqui.</div>`}
  </div>

  <div class="grid">
    <div class="card">
      <div class="h">Pedidos recebidos</div>
      ${incomingRequests.length ? incomingRequests.map(r => `
        <div class="row">
          <div><a href="/u/${r.username}">${r.username}</a> ${r.full_name ? `(${r.full_name})` : ""}</div>
          <form method="post" action="/friends/accept/${r.id}"><button class="btn" type="submit">Aceitar</button></form>
          <form method="post" action="/friends/reject/${r.id}"><button class="btn danger" type="submit">Recusar</button></form>
        </div><hr/>
      `).join("") : `<div class="small">Nada aqui.</div>`}
    </div>

    <div class="card">
      <div class="h">Pedidos enviados</div>
      ${outgoingRequests.length ? outgoingRequests.map(r => `
        <div class="row">
          <div><a href="/u/${r.username}">${r.username}</a> — <span class="badge">${r.status}</span></div>
        </div><hr/>
      `).join("") : `<div class="small">Nada aqui.</div>`}
    </div>
  </div>
` }) %>
