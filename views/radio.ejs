<%- include("layout", { title: "Rádio Klein Dream", body: `
  <div class="card radio-page-shell">
    <div class="radio-hero">
      <div>
        <div class="h" style="font-size:1.6rem;margin-bottom:4px;">🎧 Rádio Klein Dream</div>
        <div class="small muted">Escolha um estilo, aperte o play e fique por aqui. Ao sair da página, a música para.</div>
      </div>
      <a class="btn secondary" href="/home">⬅ Voltar para a rede</a>
    </div>

    <div class="radio-grid">
      <div>
        <div class="card radio-player-card">
          <div class="small muted">Agora na vitrola</div>
          <div class="radio-station-title">${station.emoji} ${escapeHtml(station.name)}</div>
          <div class="radio-station-subtitle">${escapeHtml(station.subtitle)}</div>

          <div class="radio-station-list">
            ${stations.map(s => `
              <a class="radio-station-chip ${s.key === station.key ? 'active' : ''}" href="/radio?station=${encodeURIComponent(s.key)}">
                <span>${s.emoji}</span>
                <span>${escapeHtml(s.name)}</span>
              </a>
            `).join('')}
          </div>

          <div class="radio-controls">
            <button class="btn" type="button" id="radioPlayBtn">▶ Tocar</button>
            <button class="btn secondary" type="button" id="radioPauseBtn">⏸ Pausar</button>
          </div>

          <div class="radio-note-box">
            <div><b>Clima:</b> rádio simples, sem vídeo aparecendo, sem bagunça.</div>
            <div class="small muted" style="margin-top:4px;">Se trocar de página, o som para. É um cantinho da Klein Dream, não um player grudado no site inteiro.</div>
          </div>

          <div class="radio-mini-tips">
            <span>💙 comenta o que essa vibe te lembra</span>
            <span>✨ ideal pra navegar com calma</span>
            <span>🕹 no estilo internet boa</span>
          </div>

          <div id="radioFrameWrap" aria-hidden="true" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;"></div>
        </div>
      </div>

      <div>
        <div class="card radio-comments-card">
          <div class="h" style="font-size:1.2rem;">💬 Comentários da rádio</div>
          <div class="small muted" style="margin-top:4px;">Vale memória, opinião, nostalgia e indicação. Mantendo respeito, tá valendo.</div>

          <form method="post" action="/radio/comment" class="radio-comment-form">
            <input type="hidden" name="station" value="${escapeHtml(station.key)}" />
            <textarea name="content" rows="4" maxlength="280" placeholder="Essa seleção me lembra..." required></textarea>
            <div class="radio-comment-actions">
              <span class="small muted">Até 280 caracteres.</span>
              <button class="btn" type="submit">Enviar comentário</button>
            </div>
          </form>

          ${comments && comments.length ? `
            <div class="radio-comment-list">
              ${comments.map(c => `
                <div class="radio-comment-item">
                  <div class="radio-comment-head">
                    <a href="/u/${c.username}" class="radio-comment-user">
                      <img src="${photoSrc(c.profile_photo)}" alt="${escapeHtml(c.username)}" class="radio-comment-avatar" />
                      <span>${escapeHtml(c.full_name || c.username)}</span>
                    </a>
                    <span class="small muted">${escapeHtml(c.created_at)}</span>
                  </div>
                  <div class="radio-comment-text">${escapeHtml(c.content)}</div>
                </div>
              `).join('')}
            </div>
          ` : `
            <div class="radio-empty-state">Ainda não comentaram nesta estação. Seja o primeiro a deixar uma lembrança 💙</div>
          `}
        </div>
      </div>
    </div>
  </div>

  <script>
    (function(){
      const wrap = document.getElementById('radioFrameWrap');
      const playBtn = document.getElementById('radioPlayBtn');
      const pauseBtn = document.getElementById('radioPauseBtn');
      const videoId = ${JSON.stringify(station.youtubeId)};
      let playing = false;

      function stopRadio() {
        wrap.innerHTML = '';
        playing = false;
      }

      function startRadio() {
        wrap.innerHTML = '<iframe width="1" height="1" src="https://www.youtube.com/embed/' + videoId + '?autoplay=1&controls=0&loop=1&playlist=' + videoId + '" title="Rádio Klein Dream" frameborder="0" allow="autoplay; encrypted-media" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>';
        playing = true;
      }

      playBtn.addEventListener('click', function(){
        if (playing) return;
        startRadio();
      });

      pauseBtn.addEventListener('click', function(){
        stopRadio();
      });

      window.addEventListener('beforeunload', stopRadio);
    })();
  </script>
`}) %>

<% function escapeHtml(s){ return String(s||"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;"); } %>
