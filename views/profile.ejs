<%- include("layout", { title: user.username, body: `
  <div class="profile-page orkut-profile-layout">
    <aside class="profile-sidebar profile-sidebar-left">
      <div class="card profile-side-card">
        <div class="profile-side-user">
          <div class="profile-side-photo">
            ${ user.profile_photo ? `<img src="${photoSrc(user.profile_photo)}" alt="Foto de perfil" class="kd-zoom" />` : `<div class="profile-photo-ph">Sem foto</div>` }
          </div>
          <div>
            <div class="profile-side-name">${user.username}${isBirthdayToday ? ' 🎂' : ''}</div>
            <div class="small">${user.full_name || ""}</div>
          </div>
        </div>

        <div class="profile-side-links-title">Menu do perfil</div>
        <div class="profile-side-links">
          <a href="/u/${user.username}">👤 Perfil</a>
          <a href="/scraps/${user.username}">📝 Recados</a>
          <a href="/testimonials/${user.username}">💬 Depoimentos</a>
          <a href="/photos/${user.username}">📷 Fotos</a>
          <a href="/fans/${user.username}">⭐ Fãs</a>
          ${isMe ? `<a href="/me/visitors">👁 Visitantes</a>` : ``}
          ${isMe ? `<a href="/profile/edit">⚙️ Editar perfil</a>` : ``}
          <a href="javascript:history.back()">⬅ Voltar</a>
        </div>
      </div>
    </aside>

    <div class="profile-main-column">
      <div class="card profile-hero">
        <div class="profile-hero-top">
          <div class="profile-photo profile-hero-photo">
            ${ user.profile_photo ? `<img src="${photoSrc(user.profile_photo)}" alt="Foto de perfil" class="kd-zoom" />` : `<div class="profile-photo-ph">Sem foto</div>` }
          </div>

          <div class="profile-meta">
            <div class="profile-name">
              <div class="profile-username">${user.username}${isBirthdayToday ? ' 🎂' : ''}</div>
              <div class="small">${user.full_name || ""}</div>
            </div>

            <div class="profile-actions">
              ${isMe ? `
                <a class="btn" href="/profile/edit">Editar perfil</a>
              ` : `
                ${friend ? `<span class="badge">Vocês são amigos</span>` : ``}

                ${(!friend && !reqOut && !reqIn) ? `
                  <form method="post" action="/friends/request/${user.id}" class="inline">
                    <button class="btn" type="submit">Adicionar como amigo</button>
                  </form>
                ` : ``}

                ${reqOut ? `<span class="badge">Pedido enviado</span>` : ``}
                ${reqIn ? `<span class="badge">Você tem um pedido dele(a)</span>` : ``}
              `}
            </div>

            <div class="profile-stats">
              ${user.mood ? `<div class="stat"><div class="k">Humor</div><div class="v">${escapeHtml(user.mood)}</div></div>` : ``}
            </div>
          </div>
        </div>

        ${isBirthdayToday ? `
          <div class="profile-birthday-banner">
            <div class="h" style="margin:0 0 4px 0;">🎉 Hoje é aniversário deste usuário!</div>
            <div class="kd-mini-muted">Passe nos recados e deixe uma mensagem especial.</div>
          </div>
        ` : ``}

        <div class="profile-hero-body">
          <div class="profile-kv">
            <div class="small">Cidade</div><div>${escapeHtml(user.city || "-")}</div>
            <div class="small">Estado</div><div>${escapeHtml(user.state || "-")}</div>
            <div class="small">Nascimento</div><div>${escapeHtml(user.birth_date || "-")}</div>
            <div class="small">Estado civil</div><div>${escapeHtml(user.marital_status || "-")}</div>
            <div class="small">Time</div><div>${escapeHtml(user.favorite_team || "-")}</div>
            <div class="small">Profissão</div><div>${escapeHtml(user.profession || "-")}</div>
            <div class="small">Procura</div><div>${escapeHtml(user.looking_for || "-")}</div>
            <div class="small">Membro desde</div><div>${escapeHtml(memberSince || "-")}</div>
          </div>

          ${user.daily_phrase ? `
            <div class="profile-highlight">
              <div class="small">Frase do dia</div>
              <div>${escapeHtml(user.daily_phrase)}</div>
            </div>
          ` : ``}

          <div class="profile-about">
            <div class="small">Sobre</div>
            <div>${escapeHtml(user.bio || "—")}</div>
          </div>

          <div class="profile-highlight">
            <div class="h">⭐ Fãs</div>
            <div class="small" style="margin-bottom:8px;">${fansCount} pessoa${fansCount === 1 ? '' : 's'} ${fansCount === 1 ? 'é fã' : 'são fãs'} deste perfil.</div>
            ${!isMe ? `
              <form method="post" action="/fan/${user.username}" class="inline" style="margin-bottom:10px;">
                <button class="btn" type="submit">${isFan ? 'Deixar de ser fã' : 'Virar fã'}</button>
              </form>
            ` : ``}
            ${recentFans.length ? `
              <div class="thumb-grid">
                ${recentFans.map(f => `
                  <a class="thumb-card" href="/u/${f.username}" title="${escapeHtml(f.username)}">
                    ${f.profile_photo ? `<img class="thumb-avatar kd-zoom" src="${photoSrc(f.profile_photo)}" alt="${escapeHtml(f.username)}" />` : `<div class="thumb-avatar ph">?</div>`}
                    <div class="thumb-name">${escapeHtml(f.username)}</div>
                  </a>
                `).join('')}
              </div>
            ` : `<div class="small">Ainda não há fãs por aqui.</div>`}
            <div style="margin-top:10px;"><a class="btn secondary" href="/fans/${user.username}">Ver todos os fãs</a></div>
          </div>

          ${(user.hobbies || user.favorite_music || user.favorite_movie || user.favorite_game || user.personality) ? `
            <div class="profile-highlight">
              <div class="h">Gostos</div>
              <div class="profile-kv">
                <div class="small">Hobbies</div><div>${escapeHtml(user.hobbies || "-")}</div>
                <div class="small">Música</div><div>${escapeHtml(user.favorite_music || "-")}</div>
                <div class="small">Filme</div><div>${escapeHtml(user.favorite_movie || "-")}</div>
                <div class="small">Jogo</div><div>${escapeHtml(user.favorite_game || "-")}</div>
                <div class="small">Personalidade</div><div>${escapeHtml(user.personality || "-")}</div>
              </div>
            </div>
          ` : ``}
        </div>
      </div>

      ${isMe ? `
        <div class="card">
          <div class="h">Últimos visitantes</div>
          ${canSeeVisitors ? `
            ${visitors.length ? visitors.map(v => `
              <div class="visitor-item">
                ${ v.profile_photo ? `<img src="${photoSrc(v.profile_photo)}" alt="Foto" />` : `<div class="visitor-ph">?</div>` }
                <div>
                  <div><a href="/u/${v.username}"><b>${v.username}</b></a></div>
                  <div class="small">${v.created_at}</div>
                </div>
              </div>
            `).join("") : `<div class="small">Nenhuma visita ainda.</div>`}
            <hr/>
            <a class="btn secondary" href="/me/visitors">Ver histórico</a>
          ` : `
            <div class="small">Você está com <b>Modo Invisível</b> ativado. Visitas não são registradas, e por regra você não vê a lista.</div>
            <div style="margin-top:8px;"><a class="btn secondary" href="/profile/edit">Ajustar privacidade</a></div>
          `}
        </div>
      ` : ``}


      <div class="card profile-activity">
        <div class="section">
          <div class="h">Recados (últimos)</div>
          ${scraps.length ? scraps.map(s => `
            <div class="item">
              <div class="small">de <a href="/u/${s.from_username}"><b>${s.from_username}</b></a> • ${s.created_at}</div>
              <div>${escapeHtml(s.content)}</div>
            </div>
          `).join("") : `<div class="small">Sem recados.</div>`}
          <div style="margin-top:10px;"><a class="btn secondary" href="/scraps/${user.username}">Ver todos</a></div>
        </div>

        <div class="divider"></div>

        <div class="section">
          <div class="h">Depoimentos (aprovados)</div>
          ${testimonials.length ? testimonials.map(t => `
            <div class="item">
              <div class="small">de <a href="/u/${t.from_username}"><b>${t.from_username}</b></a> • ${t.created_at}</div>
              <div>${escapeHtml(t.content)}</div>
            </div>
          `).join("") : `<div class="small">Sem depoimentos aprovados.</div>`}
          <div style="margin-top:10px;"><a class="btn secondary" href="/testimonials/${user.username}">Ver</a></div>
        </div>
      </div>
    </div>

    <aside class="profile-sidebar profile-sidebar-right">
      <div class="card profile-side-card right-side-card">
        <div class="h">Amigos (${friendsCount})</div>
        ${profileFriends.length ? `
          <div class="orkut-thumb-grid friends-grid">
            ${profileFriends.map(f => `
              <a class="orkut-thumb-card" href="/u/${f.username}" title="${escapeHtml(f.username)}">
                ${f.profile_photo ? `<img class="orkut-thumb-avatar kd-zoom" src="${photoSrc(f.profile_photo)}" alt="${escapeHtml(f.username)}" />` : `<div class="orkut-thumb-avatar ph">?</div>`}
                <div class="orkut-thumb-name">${escapeHtml(f.username)}</div>
              </a>
            `).join('')}
          </div>
        ` : `<div class="small">Nenhum amigo para mostrar ainda.</div>`}
        <div style="margin-top:10px;"><a class="btn secondary" href="/friends">Ver amigos</a></div>
      </div>

      <div class="card profile-side-card right-side-card">
        <div class="h">Grupos (${groupsCount})</div>
        ${profileGroups.length ? `
          <div class="orkut-thumb-grid groups-grid">
            ${profileGroups.map(g => `
              <a class="orkut-thumb-card group" href="/groups/${g.id}" title="${escapeHtml(g.name)}">
                <div class="orkut-group-icon">👥</div>
                <div class="orkut-thumb-name">${escapeHtml(g.name)}</div>
                <div class="orkut-thumb-meta">${escapeHtml(g.category || 'Sem categoria')}</div>
              </a>
            `).join('')}
          </div>
        ` : `<div class="small">Este perfil ainda não entrou em grupos.</div>`}
        <div style="margin-top:10px;"><a class="btn secondary" href="/groups">Ver grupos</a></div>
      </div>
    </aside>
  </div>
` }) %>

<% function escapeHtml(str){ return String(str).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m])); } %>
