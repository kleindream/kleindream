<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title || "KleinDream" %></title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div id="kdLoader" class="kd-loader" aria-hidden="true">
    <div class="kd-loader-inner">
      <div class="kd-spinner" aria-hidden="true"></div>
      <div class="kd-loader-text">Conectando…</div>
      <div class="kd-loader-sub">um segundinho 💙</div>
    </div>
  </div>

  <div id="kdToasts" class="kd-toasts" aria-live="polite" aria-atomic="true"></div>

  <div class="topbar">
    <div class="container">
      <div class="brand"><a href="/"><span>Klein</span>Dream</a></div>

      <div class="nav">
        <% if (me) { %>
          <a href="/home">🏠 Início</a>
          <a href="/friends">👥 Amigos</a>
          <a href="/chat">💬 Bate-papo</a>
          <a href="/search">🔎 Buscar</a>
          <a href="/fans/<%= me.username %>">⭐ Fãs</a>
          <a href="/groups">👪 Grupos</a>
          <a href="/messages">✉️ Mensagens</a>
          <a class="nav-pill nav-profile" href="/u/<%= me.username %>">👤 Meu perfil</a>
          <a href="/mural">📰 Mural</a>
          <a href="/nosso-tempo">🕰 Nosso Tempo</a>
          <a href="/notifications">🔔 Notificações <span class="badge <%= (notifCount||0) > 0 ? 'pulse' : '' %>"><%= notifCount %></span></a>
          <a href="/about">ℹ️ Sobre</a>
          <a href="/me/visitors">👁 Visitantes</a>
          <button id="kdThemeToggle" class="btn ghost" type="button" title="Trocar tema">Tema</button>
          <form method="post" action="/logout" style="display:inline;">
            <button class="btn secondary" type="submit">Sair</button>
          </form>
        <% } else { %>
          <a href="/login">Entrar</a>
          <a href="/register">Criar conta</a>
          <a href="/about">Sobre</a>
        <% } %>
      </div>
    </div>
  </div>

  <div class="container">
    <%- body %>
    <div class="small" style="margin:20px 0 10px 0; opacity:.8;">
      KleinDream — estilo 2004 • sem timeline
    </div>
  </div>

  <div id="kdModal" class="kd-modal" aria-hidden="true">
    <div class="inner">
      <button class="close" type="button" aria-label="Fechar">×</button>
      <img id="kdModalImg" src="" alt="Imagem ampliada" />
    </div>
  </div>

  <script>
    (function () {
      const modal = document.getElementById("kdModal");
      const img = document.getElementById("kdModalImg");
      const closeBtn = modal.querySelector(".close");

      function open(src, alt) {
        img.src = src;
        img.alt = alt || "Imagem ampliada";
        modal.classList.add("open");
        modal.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
      }
      function close() {
        modal.classList.remove("open");
        modal.setAttribute("aria-hidden", "true");
        img.src = "";
        document.body.style.overflow = "";
      }

      document.addEventListener("click", function (e) {
        const t = e.target;
        if (t && t.tagName === "IMG" && t.classList.contains("kd-zoom")) {
          e.preventDefault();
          open(t.src, t.alt);
        }
      });

      closeBtn.addEventListener("click", close);
      modal.addEventListener("click", function (e) {
        if (e.target === modal) close();
      });
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") close();
      });
    })();
  </script>

  
  <script>
    // Flash -> toasts
    (function(){
      const flash = <%- JSON.stringify(flash || {}) %>;
      if (!flash) return;
      function push(list, type){
        if (!list) return;
        (Array.isArray(list)?list:[list]).forEach(m=>{
          if (m) window.kdToast && window.kdToast(String(m), type);
        });
      }
      push(flash.success, 'success');
      push(flash.error, 'error');
      push(flash.info, 'info');
    })();
  </script>
<script src="/kd.js"></script>
</body>
</html>
