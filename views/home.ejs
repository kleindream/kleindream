<%- include("layout", { title: "Início", body: `
  <div class="dashboard-shell">
    <section class="card dashboard-hero">
      <div class="dashboard-hero-copy">
        <div class="eyebrow">Painel do Klein Dream</div>
        <div class="dashboard-title">Bem-vindo de volta, ${(me && (me.full_name || me.username)) ? escapeHtml(me.full_name || me.username) : ""}.</div>
        <p class="dashboard-lead">
          Aqui o começo da sua rede já mostra o que importa: gente, recados, movimento e atalhos.
          Sem confusão, sem pressa e sem te empurrar coisa que você não pediu.
        </p>
      </div>
      <div class="dashboard-hero-actions">
        <a class="button" href="/u/${me.username}">👤 Meu perfil</a>
        <a class="button secondary" href="/mural">📰 Ir pro mural</a>
        <a class="button secondary" href="/search">🔎 Procurar gente</a>
        <a class="button secondary" href="/profile/edit">✏️ Editar perfil</a>
      </div>
    </section>

    <section class="dashboard-stats-grid">
      <a class="card stat-card" href="/friends">
        <div class="stat-label">👥 Amigos</div>
        <div class="stat-value">${dashboardStats?.friends || 0}</div>
        <div class="stat-meta">laços já confirmados</div>
      </a>
      <a class="card stat-card" href="/fans/${me.username}">
        <div class="stat-label">⭐ Fãs</div>
        <div class="stat-value">${dashboardStats?.fans || 0}</div>
        <div class="stat-meta">quem curte seu perfil</div>
      </a>
      <a class="card stat-card" href="/scraps/${me.username}">
        <div class="stat-label">💬 Recados</div>
        <div class="stat-value">${dashboardStats?.scraps || 0}</div>
        <div class="stat-meta">mensagens no seu cantinho</div>
      </a>
      <a class="card stat-card" href="/me/visitors">
        <div class="stat-label">👁 Visitantes</div>
        <div class="stat-value">${dashboardStats?.visitors || 0}</div>
        <div class="stat-meta">passagens pelo seu perfil</div>
      </a>
      <a class="card stat-card" href="/photos/${me.username}">
        <div class="stat-label">📷 Fotos</div>
        <div class="stat-value">${dashboardStats?.photos || 0}</div>
        <div class="stat-meta">memórias publicadas</div>
      </a>
      <a class="card stat-card" href="/groups">
        <div class="stat-label">👪 Grupos</div>
        <div class="stat-value">${dashboardStats?.groups || 0}</div>
        <div class="stat-meta">lugares onde você participa</div>
      </a>
    </section>

    <div class="dashboard-main-grid">
      <div class="dashboard-main-column">
        <section class="card dashboard-focus-card">
          <div class="section-title">⚡ O que merece sua atenção agora</div>
          <div class="dashboard-focus-grid">
            <div class="focus-mini-card">
              <div class="focus-title">Pedidos de amizade</div>
              <div class="focus-number">${(incomingRequests||[]).length}</div>
              <div class="focus-text">pessoas esperando sua resposta</div>
              <a class="button secondary" href="/friends">Gerenciar</a>
            </div>
            <div class="focus-mini-card">
              <div class="focus-title">Depoimentos pendentes</div>
              <div class="focus-number">${(pendingTestimonials||[]).length}</div>
              <div class="focus-text">mensagens que precisam da sua aprovação</div>
              <a class="button secondary" href="/testimonials/${me.username}">Revisar</a>
            </div>
            <div class="focus-mini-card">
              <div class="focus-title">Mensagens não lidas</div>
              <div class="focus-number">${(unreadMessages||[]).length}</div>
              <div class="focus-text">conversas esperando você abrir</div>
              <a class="button secondary" href="/messages">Abrir inbox</a>
            </div>
          </div>
        </section>

        <section class="card dashboard-list-card">
          <div class="section-title">💬 Recados recentes pra você</div>
          ${((latestScraps||[]).length === 0)
            ? `
              <div class="empty-state">Ainda não chegaram recados. Que tal mandar um primeiro recado pra alguém?</div>
              <div style="margin-top:8px;"><a class="button secondary" href="/search">Procurar pessoas</a></div>
            `
            : `
              <ul class="list dashboard-list">
                ${(latestScraps||[]).slice(0,10).map(s => `
                  <li>
                    <div>
                      <a href="/u/${s.from_username}"><b>${escapeHtml(s.from_username)}</b></a>
                      <span style="color:var(--faint);"> disse:</span>
                    </div>
                    <div class="dashboard-list-text">${escapeHtml(s.content)}</div>
                  </li>
                `).join("")}
              </ul>
              <div style="margin-top:8px;"><a class="button secondary" href="/scraps/${me.username}">Ver todos</a></div>
            `}
        </section>
      </div>

      <aside class="dashboard-side-column">
        <section class="card dashboard-list-card compact">
          <div class="section-title">👥 Pedidos de amizade</div>
          ${((incomingRequests||[]).length === 0)
            ? `<div class="empty-state">Nenhum pedido por enquanto.</div>`
            : `
              <ul class="list dashboard-list compact-list">
                ${(incomingRequests||[]).slice(0,8).map(r => `
                  <li>
                    <a href="/u/${r.username}"><b>${escapeHtml(r.full_name || r.username)}</b></a>
                    <span style="color:var(--faint);"> pediu amizade</span>
                  </li>
                `).join("")}
              </ul>
              <div style="margin-top:8px;"><a class="button secondary" href="/friends">Ver pedidos</a></div>
            `}
        </section>

        <section class="card dashboard-list-card compact">
          <div class="section-title">📝 Depoimentos pendentes</div>
          ${((pendingTestimonials||[]).length === 0)
            ? `<div class="empty-state">Nada pendente. Seu perfil está em ordem.</div>`
            : `
              <ul class="list dashboard-list compact-list">
                ${(pendingTestimonials||[]).slice(0,8).map(t => `
                  <li>
                    <a href="/u/${t.username}"><b>${escapeHtml(t.full_name || t.username)}</b></a>
                    <span style="color:var(--faint);"> deixou um depoimento</span>
                  </li>
                `).join("")}
              </ul>
              <div style="margin-top:8px;"><a class="button secondary" href="/testimonials/${me.username}">Revisar</a></div>
            `}
        </section>

        <section class="card dashboard-list-card compact">
          <div class="section-title">✉️ Mensagens não lidas</div>
          ${((unreadMessages||[]).length === 0)
            ? `<div class="empty-state">Caixa de entrada tranquila.</div>`
            : `
              <ul class="list dashboard-list compact-list">
                ${(unreadMessages||[]).slice(0,8).map(m => `
                  <li>
                    <a href="/messages"><b>${escapeHtml(m.from_username)}</b></a>
                    <span style="color:var(--faint);"> — ${escapeHtml(m.subject || "sem assunto")}</span>
                  </li>
                `).join("")}
              </ul>
              <div style="margin-top:8px;"><a class="button secondary" href="/messages">Abrir inbox</a></div>
            `}
        </section>
      </aside>
    </div>

    <section class="card dashboard-footer-note">
      <div class="section-title">💙 Seu espaço, do seu jeito</div>
      <p>
        O Klein Dream funciona melhor quando tudo está claro: primeiro o que pede atenção, depois o que mostra movimento,
        e por fim os atalhos para continuar vivendo a rede. É um painel de controle com alma de internet antiga.
      </p>
    </section>
  </div>
` }) %>

<% function escapeHtml(str){ return String(str ?? "").replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m])); } %>
