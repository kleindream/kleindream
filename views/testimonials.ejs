<%- include("layout", { title: "Depoimentos", body: `  
  <div class="card">
    <div class="h" style="font-size: 2rem; font-weight: 900; color: var(--accent);">
      Depoimentos de ${user.username}
    </div>

    <form method="post" action="/testimonials/${user.username}">
      <label class="small" style="color: var(--text);">Enviar depoimento</label>
      <textarea name="content" placeholder="Escreva um depoimento..."></textarea>
      <br/>
      <button class="button" type="submit">Enviar</button>
    </form>
  </div>

  ${pendingMine && pendingMine.length ? `
    <div class="card" style="margin-top:12px;background:var(--panel2);">
      <div class="h" style="font-size: 1.6rem; font-weight: 900; color: var(--accent);">Pendentes (para aprovar)</div>
      ${pendingMine.map(t => `
        <div class="card" style="margin-top:10px;">
          <div class="h" style="color: var(--accent);">De: ${t.from_username}</div>
          <p style="color: var(--text);">${t.content}</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;">
            <form method="post" action="/testimonials/approve/${t.id}">
              <button class="button" type="submit">Aprovar</button>
            </form>
            <form method="post" action="/testimonials/reject/${t.id}">
              <button class="button" type="submit" style="background:#5b6b82;">Rejeitar</button>
            </form>
          </div>
        </div>
      `).join("")}
    </div>
  ` : ""}

  <div class="card" style="margin-top:12px;background: var(--panel2);">
    <div class="h" style="font-size: 1.6rem; font-weight: 900; color: var(--accent);">Aprovados</div>

    ${approved && approved.length ? approved.map(t => `
      <div class="card" style="margin-top: 10px;">
        <div class="h" style="color: var(--accent);">De: ${t.from_username}</div>
        <p style="color: var(--text);">${t.content}</p>
      </div>
    `).join('') : `
      <p style="color: var(--muted);">
        Ainda não há depoimentos. Que tal enviar o primeiro?
      </p>
    `}
  </div>
` }) %>
