    <!-- FEATURES -->
    <div class="kd-card kd-section">
      <h3>Recursos em funcionamento</h3>
      <p class="kd-sub">
        Esta não é uma promessa vaga: a Klein Dream já permite interações reais. Você entra, monta seu perfil e vive a rede.
      </p>

      <div class="kd-grid">
